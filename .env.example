APP_NAME="@PlayaAlta"
APP_LOGO="img/logo_small.png"
TICKET_LOGO="img/logo_small.png"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Use the same host you type in the browser (localhost vs 127.0.0.1) to avoid cookie/session issues.
# For plain http:// local dev, leave unset or false — true prevents session cookies on non-HTTPS.
# SESSION_SECURE_COOKIE=

# Docker/Sail: match your host uid/gid if file permission issues (defaults 1000)
WWWGROUP=1000
WWWUSER=1000

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Sail: use redis service hostname and Redis for cache/session/queue
# REDIS_HOST=redis
# CACHE_DRIVER=redis
# SESSION_DRIVER=redis
# QUEUE_CONNECTION=redis

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Thermal printers (comma-separated IPs and ports, one per printer slot)
NR_OF_PRINTERS=3
PRINTER_IP='127.0.0.1,127.0.0.1,127.0.0.1'
PRINTER_PORT='9097,9098,9097'

# PayPal (use sandbox keys in development)
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=

# Ordering / UI (see config/customoptions.php)
EATIN=true
TAKE_AWAY=true
DELIVERY=false
EATIN_PREPAY=true
TAKEAWAY_PREPAY=false
DELIVERY_PREPAY=false
CLEAN_TABLE_AFTER_ORDER=false

NR_CATEGORY_BUTTONS=8
REDES_SOCIALES="@yourvenue"
INVOICE_HEADER="Your business name \n Tax ID \n Phone"
